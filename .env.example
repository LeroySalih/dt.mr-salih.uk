# Comma-separated unit_ids from dino to import. CORE_UNIT_IDS map to the "Core"
# band on the landing page; SYSTEMS_UNIT_IDS map to the "Systems" band. Lessons
# inside these units render as topic cards.
CORE_UNIT_IDS=1001-CORE-1,1003-CORE-2,CORE-3-10
SYSTEMS_UNIT_IDS=1010-SYSTEMS-1
